{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "snapshot",
      "camelcase": "Snapshot",
      "title": "Snapshot",
      "scope": "source.snapshot",
      "file-types": [
        "snapshot"
      ],
      "injection-regex": "^snapshot$",
      "class-name": "TreeSitterSnapshot"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Snapshot test files generated by Shutter",
    "authors": [
      {
        "name": "ptdewey",
        "url": "https://github.com/ptdewey"
      }
    ],
    "links": {
      "repository": "https://github.com/ptdewey/shutter"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}